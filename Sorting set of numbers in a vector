#include <iostream>
#include <sstream>
#include <math.h>
#include <vector>
using namespace std;

int main() {
  vector<int> number;
  string s;
  int i = 0;
  int sum = 0;
  while (cin >> s, s != "done") {
    stringstream ss(s);
    int x;
    ss >> x;
    number.push_back(x);
    sum += number.back();
  }
  cout << sum;
  return 0;
}



